---
layout: null
permalink: /feed.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>Varun M · Writing</title>
  <subtitle>{{ site.description }}</subtitle>
  <link href="{{ '/feed.xml' | absolute_url }}" rel="self" />
  <link href="{{ '/' | absolute_url }}" />
  <id>{{ '/' | absolute_url }}</id>
  <updated>{{ site.posts.first.date | date_to_xmlschema }}</updated>
  <author>
    <name>Varun M</name>
    <email>varun995862@gmail.com</email>
  </author>
{% for post in site.posts %}  <entry>
    <title>{{ post.title | xml_escape }}</title>
    <link href="{{ post.url | absolute_url }}" />
    <id>{{ post.url | absolute_url }}</id>
    <published>{{ post.date | date_to_xmlschema }}</published>
    <updated>{{ post.date | date_to_xmlschema }}</updated>
    <summary>{{ post.description | xml_escape }}</summary>
    <content type="html">{{ post.content | xml_escape }}</content>
  </entry>
{% endfor %}</feed>
